{
  "name": "vetlock",
  "version": "0.8.0",
  "private": false,
  "description": "Behavioral diff for npm dependency updates. What does this update DO now that it didn't before?",
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "dependencies",
    "audit",
    "sast",
    "lockfile",
    "sbom"
  ],
  "author": "Uday Ojha <OJ-Uday@users.noreply.github.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OJ-Uday/vetlock.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/OJ-Uday/vetlock#readme",
  "bugs": "https://github.com/OJ-Uday/vetlock/issues",
  "type": "module",
  "bin": {
    "vetlock": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p . && node scripts/copy-demo-fixture.mjs",
    "bundle": "pnpm --filter @vetlock/core run build && pnpm --filter @vetlock/detectors run build && tsup && node scripts/copy-detector-assets.mjs && node scripts/copy-demo-fixture.mjs",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "prepack": "pnpm run bundle"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@babel/parser": "7.29.7",
    "@babel/traverse": "7.29.7",
    "@babel/types": "7.29.7",
    "@webassemblyjs/wasm-parser": "1.14.1",
    "@yarnpkg/lockfile": "1.1.0",
    "@yarnpkg/parsers": "3.0.3",
    "commander": "12.1.0",
    "damerau-levenshtein": "1.0.8",
    "js-yaml": "4.3.0",
    "ora": "8.2.0",
    "pacote": "18.0.6",
    "picocolors": "1.1.1",
    "semver": "7.8.5",
    "ssri": "12.0.0",
    "tar": "7.5.20",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@vetlock/core": "workspace:*",
    "@vetlock/detectors": "workspace:*",
    "tsup": "8.5.1"
  }
}
