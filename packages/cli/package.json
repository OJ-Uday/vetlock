    "provenance": true
  },
  "dependencies": {
    "@vetlock/core": "workspace:*",
    "@vetlock/detectors": "workspace:*",
    "commander": "^12.0.0",
    "ora": "^8.1.0",
    "picocolors": "^1.0.0",
    "tar": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "pacote": "^18.0.0"
  }
}
