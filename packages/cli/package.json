{
  "name": "vetlock",
  "version": "0.7.0",
  "private": false,
  "description": "Behavioral diff for npm dependency updates. What does this update DO now that it didn't before?",
  "keywords": ["security", "supply-chain", "npm", "dependencies", "audit", "sast", "lockfile", "sbom"],
  "author": "Uday Ojha <OJ-Uday@users.noreply.github.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OJ-Uday/vetlock.git"
  },
  "homepage": "https://github.com/OJ-Uday/vetlock",
  "type": "module",
  "bin": {
    "vetlock": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p . && node scripts/copy-demo-fixture.js",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
