{
  "name": "vetlock",
  "version": "0.7.0",
  "private": false,
  "description": "Behavioral diff for npm dependency updates. What does this update DO now that it didn't before?",
  "keywords": [
    "security",
    "supply-chain",
    "npm",
    "dependencies",
    "audit",
    "sast",
    "lockfile",
    "sbom"
  ],
  "author": "Uday Ojha <OJ-Uday@users.noreply.github.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OJ-Uday/vetlock.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/OJ-Uday/vetlock#readme",
  "bugs": "https://github.com/OJ-Uday/vetlock/issues",
  "type": "module",
  "bin": {
    "vetlock": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p . && node scripts/copy-demo-fixture.mjs",
    "bundle": "tsup && node scripts/copy-demo-fixture.mjs && node scripts/copy-capability-map.mjs",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run bundle"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@vetlock/core": "workspace:*",
    "@vetlock/detectors": "workspace:*",
    "commander": "12.1.0",
    "ora": "8.2.0",
    "picocolors": "1.1.1",
    "tar": "7.5.20",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@vetlock/core": "workspace:*",
    "@vetlock/detectors": "workspace:*",
    "tsup": "^8.5.1"
  }
}
