# Project-local pnpm/npm config.
# Uses the public npm registry — @oj-uday/vetlock is designed to be installable
# by anyone with `npx @oj-uday/vetlock`, no proxy or auth wall. The installed
# executable remains `vetlock`.
#
# For local dev behind a corporate Zscaler proxy that requires Artifactory, add
# an untracked ~/.npmrc override or `pnpm config set --location project registry`.
registry=https://registry.npmjs.org/
